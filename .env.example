CONFLUENCE_BASE_URL=https://your-domain.atlassian.net/wiki
CONFLUENCE_EMAIL=you@example.com
CONFLUENCE_API_TOKEN=replace_with_your_token
CONFLUENCE_PAGE_LIMIT=0

# Optional ingestion default. 0 means collect every page that the account can access.
CONFLUENCE_SPACE_KEY=

# Optional. Comma-separated space keys that should rank higher as official policy sources.
CONFLUENCE_OFFICIAL_SPACES=
CONFLUENCE_SPACE_WEIGHTS=
CONFLUENCE_DOCUMENT_TYPE_WEIGHTS=정책:4,매뉴얼:3,결정사항:3,이슈:2
ADMIN_TOKEN=

# Optional. Render sets this automatically when using the free Postgres database in render.yaml.
DATABASE_URL=
